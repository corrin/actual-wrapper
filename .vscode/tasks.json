{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Actual Wrapper: Metro",
      "type": "shell",
      "command": "npx",
      "args": ["react-native", "start", "--reset-cache"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "metro",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting project at",
          "endsPattern": "Welcome to Metro"
        }
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    }
  ]
}
